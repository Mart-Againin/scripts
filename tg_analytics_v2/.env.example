# ─────────────────────────────────────────────────────────────
# TG Analytics — конфигурационный файл
# Скопируйте этот файл как .env и заполните значения
# ─────────────────────────────────────────────────────────────

# Telegram API — получить на https://my.telegram.org
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# Имя файла сессии (без расширения)
SESSION_NAME=tg_analytics

# Каналы для анализа — @username или числовой ID через запятую
CHANNELS=@channel_one,@channel_two,@channel_three

# ── Получатели отчётов ─────────────────────────────────────────────
# REPORT_RECIPIENT_ID — получают отчёты И по расписанию (автоматически
# каждую неделю/месяц), И могут запросить командой /report в любой момент.
REPORT_RECIPIENT_ID=123456789,987654321

# ── Режим отладки ──────────────────────────────────────────
# DEBUG=true — подробные логи, ежедневные отчёты, отправка на DEBUG_RECIPIENT_ID
DEBUG=false
DEBUG_RECIPIENT_ID=987654321

# MODERATOR_IDS — могут запрашивать отчёты командой /report,
# но НЕ входят в автоматическую рассылку по расписанию.
# Любой отчёт, запрошенный командой, приходит лично тому, кто его запросил —
# не дублируется остальным, независимо от того, в каком он поле.
MODERATOR_IDS=

# ── Расписание ─────────────────────────────────────────────
# Часовой пояс для расписания отчётов (например Europe/Moscow)
TIMEZONE=Europe/Moscow

# Время ежедневного тестового отчёта (только при DEBUG=true), формат HH:MM
DAILY_REPORT_TIME=12:00

# ── Папки ──────────────────────────────────────────────────
OUTPUT_DIR=output
REGISTRY_DIR=registry
ARCHIVE_DIR=archive
LOGS_DIR=logs

# ── Веса CQI ───────────────────────────────────────────────
CQI_W_REACT=1
CQI_W_VOTE=2
CQI_W_FORWARD=4
CQI_W_COMMENT=5

# ── Прокси (опционально) ───────────────────────────────────
# PROXY_TYPE=socks5
# PROXY_HOST=127.0.0.1
# PROXY_PORT=1080
# PROXY_USERNAME=
# PROXY_PASSWORD=
