# =============================================================
# tg-channel-monitor — configuration template
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================


# -------------------------------------------------------------
# GLOBAL — required
# -------------------------------------------------------------

# Telegram API credentials from https://my.telegram.org
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# Your Telegram numeric user ID (get it from @userinfobot)
# Receives /ping, /status, /update_meta commands
MASTER_ID=123456789


# -------------------------------------------------------------
# PROJECT 1
# -------------------------------------------------------------

# Channels to monitor: usernames and/or numeric IDs, comma-separated
CHANNELS_1=rbc_news,kommersant,-1001234567890

# Telegram user ID who receives alerts for this project
OWNER_1=123456789

# Person names to watch for (case-insensitive, partial match)
PEOPLE_1=Иванов,Петров Алексей,Сидорова

# Company/org names to watch for
COMPANIES_1=Газпром,Роснефть,ВТБ


# -------------------------------------------------------------
# PROJECT 2
# -------------------------------------------------------------

CHANNELS_2=interfax_russia,tass_agency
OWNER_2=987654321

PEOPLE_2=Смирнов,Кузнецова Елена
COMPANIES_2=Сбербанк,Яндекс,Mail.ru Group


# -------------------------------------------------------------
# PROJECT 3 — example with numeric-only channel IDs
# -------------------------------------------------------------

CHANNELS_3=-1009876543210,-1001122334455
OWNER_3=111222333

PEOPLE_3=Новиков
COMPANIES_3=Лукойл


# -------------------------------------------------------------
# PROJECT 4–10: add more projects following the same pattern
# A project is activated when both CHANNELS_N and OWNER_N are set.
# PEOPLE_N and COMPANIES_N are optional but at least one should
# be non-empty, otherwise no alerts will ever fire.
# -------------------------------------------------------------

# CHANNELS_4=
# OWNER_4=
# PEOPLE_4=
# COMPANIES_4=


# -------------------------------------------------------------
# CHANNEL TAGS — optional display labels in alerts
# -------------------------------------------------------------
#
# Format:  username:tag;username:[None]
#
#   username  — channel username exactly as in CHANNELS_N (no @)
#   tag       — any string, typically an emoji or short label
#   [None]    — explicitly sets no tag for that channel
#
# Tags are shown at the start of each alert:
#   🔴 Channel Name (50,000 subscribers) #Keyword
#
CHANNEL_TAGS=rbc_news:🔴;kommersant:📰;interfax_russia:📡;tass_agency:🏛


# -------------------------------------------------------------
# Notes
# -------------------------------------------------------------
#
# - Keyword matching is case-insensitive and uses regex word boundaries.
# - Multi-word keywords work: "Петров Алексей" matches the full phrase.
# - Channel metadata (tags + subscriber counts) is refreshed weekly.
#   Run /update_meta in Telegram to force an immediate refresh.
# - user.session is created on first run — keep it safe, never commit it.
