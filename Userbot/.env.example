# =============================================================
# tg-channel-monitor — configuration template
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================


# -------------------------------------------------------------
# GLOBAL — required
# -------------------------------------------------------------

API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# Your Telegram numeric user ID (get from @userinfobot)
MASTER_ID=123456789


# -------------------------------------------------------------
# BOT_MODE — required
# -------------------------------------------------------------
#
# keyword  (default)
#   Monitors all configured channels.
#   Forwards ONLY posts that match at least one keyword from
#   PEOPLE_N or COMPANIES_N. Sends a short excerpt with the
#   matching keywords highlighted.
#   digest.py is NOT needed in this mode.
#
# digest
#   Monitors all configured channels.
#   Forwards ALL posts regardless of content.
#   Long posts are summarised (annotation + key theses).
#   Requires digest.py in the same folder + sumy installed.
#   Keywords (PEOPLE_N / COMPANIES_N) are ignored.
#
BOT_MODE=keyword


# -------------------------------------------------------------
# DIGEST SETTINGS — only used when BOT_MODE=digest
# -------------------------------------------------------------
#
# Installation:
#   pip install sumy
#   python -c "import nltk; nltk.download('punkt_tab')"
#
# Scale thresholds (characters). Must be strictly ascending.
# Posts <= SHORT_LIMIT are forwarded in full.
#
DIGEST_SHORT_LIMIT=800
DIGEST_MEDIUM_LIMIT=1500
DIGEST_LONG_LIMIT=3000

# Number of theses extracted per zone (1–10).
DIGEST_MEDIUM_THESES=2
DIGEST_LONG_THESES=3
DIGEST_LONGREAD_THESES=4


# -------------------------------------------------------------
# PROJECT 1
# -------------------------------------------------------------

CHANNELS_1=rbc_news,kommersant,-1001234567890
OWNER_1=123456789

# Used in keyword mode only. Ignored in digest mode.
PEOPLE_1=Иванов,Петров Алексей,Сидорова
COMPANIES_1=Газпром,Роснефть,ВТБ


# -------------------------------------------------------------
# PROJECT 2
# -------------------------------------------------------------

CHANNELS_2=interfax_russia,tass_agency
OWNER_2=987654321

PEOPLE_2=Смирнов,Кузнецова Елена
COMPANIES_2=Сбербанк,Яндекс


# -------------------------------------------------------------
# PROJECT 3 — numeric-only channel IDs
# -------------------------------------------------------------

CHANNELS_3=-1009876543210,-1001122334455
OWNER_3=111222333

PEOPLE_3=Новиков
COMPANIES_3=Лукойл


# -------------------------------------------------------------
# PROJECT 4–10
# -------------------------------------------------------------

# CHANNELS_4=
# OWNER_4=
# PEOPLE_4=
# COMPANIES_4=


# -------------------------------------------------------------
# CHANNEL TAGS — optional
# -------------------------------------------------------------
#
# Format:  username:tag;username:[None]
# [None]   explicitly disables the tag for that channel.
#
CHANNEL_TAGS=rbc_news:🔴;kommersant:📰;interfax_russia:📡;tass_agency:🏛
